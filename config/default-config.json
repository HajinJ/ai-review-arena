  "escalation_triggers": {
    "enabled": true,
    "patterns": {
      "auth_security": {
        "file_patterns": ["*auth*", "*login*", "*session*", "*credential*", "*password*", "*token*", "*oauth*", "*jwt*"],
        "content_patterns": ["bcrypt", "argon2", "jwt\\.sign", "jwt\\.verify", "createSession", "destroySession", "setPassword", "hashPassword"],
        "min_intensity": "deep",
        "require_human_approval": false,
        "block_auto_fix": true,
        "description_ko": "인증/세션 관리",
        "description_en": "Authentication and session management"
      },
      "payment_billing": {
        "file_patterns": ["*payment*", "*billing*", "*subscription*", "*checkout*", "*stripe*", "*purchase*"],
        "content_patterns": ["charge", "refund", "subscription", "invoice", "price", "currency"],
        "min_intensity": "deep",
        "require_human_approval": true,
        "block_auto_fix": true,
        "description_ko": "결제/과금 로직",
        "description_en": "Payment processing and billing"
      },
      "database_schema": {
        "file_patterns": ["*migration*", "*schema*", "*.sql"],
        "content_patterns": ["ALTER TABLE", "DROP TABLE", "CREATE TABLE", "ADD COLUMN", "DROP COLUMN"],
        "min_intensity": "standard",
        "require_human_approval": true,
        "block_auto_fix": true,
        "description_ko": "DB 스키마 변경",
        "description_en": "Database schema modifications"
      },
      "crypto_secrets": {
        "file_patterns": ["*crypto*", "*encrypt*", "*secret*", "*.env*"],
        "content_patterns": ["encrypt", "decrypt", "AES", "RSA", "HMAC", "SECRET", "API_KEY", "PRIVATE_KEY"],
        "min_intensity": "deep",
        "require_human_approval": true,
        "block_auto_fix": true,
        "description_ko": "암호화/시크릿 관리",
        "description_en": "Cryptographic operations and secrets"
      },
      "dependency_change": {
        "file_patterns": ["package.json", "requirements.txt", "Pipfile", "go.mod", "Cargo.toml", "pom.xml", "build.gradle", "Gemfile", "*.lock"],
        "content_patterns": [],
        "min_intensity": "standard",
        "require_human_approval": false,
        "block_auto_fix": true,
        "description_ko": "의존성 변경",
        "description_en": "Dependency changes"
      },
      "infrastructure": {
        "file_patterns": ["Dockerfile*", "docker-compose*", "*.tf", ".github/workflows/*", "Jenkinsfile"],
        "content_patterns": ["deploy", "container", "service", "ingress"],
        "min_intensity": "standard",
        "require_human_approval": false,
        "block_auto_fix": true,
        "description_ko": "인프라/배포 설정",
        "description_en": "Infrastructure and deployment"
      }
    }
  },
