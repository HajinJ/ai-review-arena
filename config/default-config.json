      "position_bias_mitigation": true,
      "judge_model": "sonnet",
      "evaluation_criteria": ["finding_accuracy", "severity_calibration", "suggestion_quality", "report_completeness"]
    },
    "auto_run_after_review": false,
    "report_dir": "cache/evaluation-reports"
  },
  "static_analysis": {
    "enabled": true,
