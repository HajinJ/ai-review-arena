{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "model": { "type": "string" },
    "role": { "type": "string" },
    "mode": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
          "location": {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "section": { "type": "string" },
              "line": { "type": "number" }
            },
            "required": ["file", "section"]
          },
          "title": { "type": "string" },
          "doc_type": { "type": "string" },
          "category": { "type": "string", "enum": ["accuracy", "completeness", "freshness", "readability", "examples", "consistency"] },
          "related_source": { "type": "string" },
          "description": { "type": "string" },
          "suggestion": { "type": "string" }
        },
        "required": ["severity", "confidence", "location", "title", "doc_type", "category", "description", "suggestion"],
        "additionalProperties": false
      }
    },
    "summary": { "type": "string" }
  },
  "required": ["model", "role", "mode", "findings", "summary"],
  "additionalProperties": false
}
