    "scanners": {
      "semgrep": {"enabled": true, "timeout_seconds": 120},
      "eslint": {"enabled": true, "timeout_seconds": 60},
      "bandit": {"enabled": true, "timeout_seconds": 60},
      "gosec": {"enabled": true, "timeout_seconds": 60},
      "brakeman": {"enabled": true, "timeout_seconds": 60},
      "cargo_audit": {"enabled": true, "timeout_seconds": 60}
